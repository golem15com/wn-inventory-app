# Keep the build context lean. vendor/ is built INSIDE the image (D-14), never
# shipped from the host. Secrets (.env) and the SPA build output never enter a
# layer (T-11-21 / T-11-24).

# VCS + planning
.git
.gitignore
.gitmodules
.github
.planning
*.md
!README.md

# Composer artifacts — vendor/ is resolved in the builder stage
vendor
composer.phar

# Node / SPA build output. The Vue app (vue-inventory-app) is built into its OWN
# image by docker/spa.Dockerfile via `pnpm generate`, so its SOURCE (incl.
# package.json + pnpm-lock.yaml) MUST reach the build context — only its build
# ARTIFACTS below are excluded to keep the context lean.
node_modules
vue-inventory-app/node_modules
vue-inventory-app/.nuxt
vue-inventory-app/.output
vue-inventory-app/dist
inventory-mcp/node_modules
inventory-mcp/dist

# Secrets & local env — NEVER bake into an image layer
.env
.env.*
!.env.docker.example

# Generated public mirror + temp (winter:mirror runs at boot in the entrypoint)
public
temp

# Runtime state — regenerated in-container
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/cms/*
# NEVER bake a database into the image. A bare `*.sqlite` only matches the context
# ROOT — it does NOT match storage/database.sqlite — so without the nested globs the
# dev DB (real users + data) ships inside the published image and seeds every volume.
*.sqlite
**/*.sqlite
storage/*.sqlite
storage/app/uploads/*
typesense-data

# Editor / OS cruft
.idea
.vscode
.DS_Store
.phpunit.result.cache
.phpunit.cache
php_errors.log
