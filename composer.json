{
    "name": "golem15/inventory",
    "description": "Personal/household inventory catalog on the Golem15 stack (WinterCMS) — record what you own, which category, and where it lives, with permission-scoped Typesense search.",
    "homepage": "https://github.com/golem15com/wn-inventory-app",
    "type": "project",
    "keywords": ["inventory", "catalog", "golem15", "wintercms", "laravel", "typesense"],
    "license": "MIT",
    "authors": [
        {
            "name": "Golem15",
            "homepage": "https://github.com/golem15com",
            "role": "Maintainer"
        },
        {
            "name": "Alexey Bobkov",
            "email": "aleksey.bobkov@gmail.com",
            "role": "Original Author"
        },
        {
            "name": "Samuel Georges",
            "email": "daftspunky@gmail.com",
            "role": "Original Author"
        },
        {
            "name": "Luke Towers",
            "email": "wintercms@luketowers.ca",
            "role": "Lead Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/golem15com/wn-inventory-app/issues",
        "source": "https://github.com/golem15com/wn-inventory-app"
    },
    "require": {
        "php": ">=8.1",
        "winter/storm": "~1.2.0",
        "winter/wn-system-module": "~1.2.0",
        "winter/wn-backend-module": "~1.2.0",
        "winter/wn-cms-module": "~1.2.0",
        "laravel/framework": "^9.1",
        "wikimedia/composer-merge-plugin": "~2.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.8",
        "mockery/mockery": "^1.4.4",
        "fakerphp/faker": "^1.9.2",
        "squizlabs/php_codesniffer": "^3.2",
        "php-parallel-lint/php-parallel-lint": "^1.0",
        "dms/phpunit-arraysubset-asserts": "^0.1.0|^0.2.1",
        "cweagans/composer-patches": "^2.0",
        "phpstan/phpstan": "^1.12",
        "larastan/larastan": "^2.9",
        "phpstan/phpstan-strict-rules": "^1.6",
        "enlightn/security-checker": "^1.10",
        "pheromone/phpcs-security-audit": "^2.0"
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php artisan winter:install",
            "@php artisan winter:env",
            "@php artisan winter:mirror public --relative"
        ],
        "post-install-cmd": [
            "patch -p1 -d vendor/winter/storm < patches/winter-storm-php84-null-offset.patch 2>/dev/null || true"
        ],
        "post-update-cmd": [
            "patch -p1 -d vendor/winter/storm < patches/winter-storm-php84-null-offset.patch 2>/dev/null || true",
            "@php artisan winter:version",
            "@php artisan package:discover"
        ],
        "test": [
            "phpunit --stop-on-failure"
        ],
        "lint": [
            "parallel-lint --exclude vendor --exclude storage --exclude modules/system/tests/fixtures/plugins/testvendor/goto/Plugin.php ."
        ],
        "sniff": [
            "phpcs --colors -nq --report=\"full\" --extensions=\"php\""
        ],
        "scan:audit": "composer audit --format=plain",
        "scan:enlightn": "php vendor/enlightn/security-checker/security-checker security:check composer.lock --format=json",
        "scan:phpstan": "vendor/bin/phpstan analyse --configuration=phpstan.neon --no-progress",
        "scan:phpcs": "vendor/bin/phpcs --standard=Security --extensions=php --report=full plugins/golem15/ plugins/winter/",
        "scan:patterns": "bash scripts/security-scan.sh plugins/golem15 plugins/winter",
        "scan:all": [
            "@scan:audit",
            "@scan:enlightn",
            "@scan:phpstan",
            "@scan:phpcs",
            "@scan:patterns"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "merge-plugin": {
            "include": [
                "plugins/*/*/composer.json"
            ],
            "recurse": true,
            "replace": false,
            "merge-replace": false,
            "merge-dev": false
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "wikimedia/composer-merge-plugin": true,
            "cweagans/composer-patches": false
        }
    }
}
