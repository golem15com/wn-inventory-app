# =============================================================================
# Inventory (whereiput.it) self-host env — copy to .env.docker before `up`.
# =============================================================================
#   cp .env.docker.example .env.docker
#   # set ADMIN_EMAIL + a STRONG ADMIN_PASSWORD, then:
#   docker compose --profile light up      # or --profile full
#
# Do NOT commit .env.docker — it holds your admin password & API keys.
# =============================================================================

APP_NAME="Inventory"
APP_URL=http://localhost:8088
APP_DEBUG=false
APP_LOCALE=en

# --- APP_KEY (CRITICAL — Pitfall 6 / T-11-22) --------------------------------
# Leave BLANK. The entrypoint generates it ONCE and persists it to the mounted
# storage volume, then NEVER regenerates it. Once set it must stay PERMANENT:
# rotating APP_KEY orphans every encrypted BYOK API key (DecryptException) and
# breaks realtime JWT auth. If you ever migrate hosts, copy the persisted
# storage/persisted.env (which carries APP_KEY) with the data.
APP_KEY=

# --- JWT_SECRET --------------------------------------------------------------
# Leave BLANK — generated ONCE and persisted alongside APP_KEY on first boot.
JWT_SECRET=

# --- Database ----------------------------------------------------------------
# DB_CONNECTION is set automatically by the profile: sqlite (light) / pgsql
# (full). Override here only for an advanced custom setup.
# DB_CONNECTION=sqlite
# light profile: SQLite (set automatically by compose; nothing to configure).
# full  profile: Postgres (compose wires DB_* to the postgres service). The
# values below feed the postgres container in the full profile.
POSTGRES_DB=inventory
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change-me-postgres

# --- Search (Scout / Typesense) ----------------------------------------------
# light profile: SCOUT_DRIVER unset → scoped DB-search fallback on SQLite (no
#   Typesense needed). To use Typesense in light mode, run the typesense-light
#   service (--profile light --profile light-search) and set SCOUT_DRIVER below.
# full  profile: compose sets SCOUT_DRIVER=typesense + TYPESENSE_* to the
#   typesense service automatically — you only need TYPESENSE_API_KEY.
# SCOUT_DRIVER=typesense
TYPESENSE_API_KEY=change-me-typesense-key

# --- Admin seed (D-15) -------------------------------------------------------
# The entrypoint seeds a FRONTEND admin group ('admin') + this user on first
# boot. The admin can use AI immediately via the global Golem path; non-admins
# add their own key in /settings → AI (BYOK). NO password is baked into the
# image — set a STRONG value here. To change it later, do so in-app (or wipe the
# user and re-seed); re-running with a new password does NOT overwrite an
# existing user (the seed is idempotent — change it in-app instead).
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Person

# --- Host port ---------------------------------------------------------------
# The app listens on container :80; this maps it to the host.
APP_PORT=8088
