APP_NAME="Winter CMS"
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file

SESSION_DRIVER=file

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_LOG_CHANNEL=null
MAIL_HOST=null
MAIL_PORT=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

ROUTES_CACHE=false
ASSET_CACHE=false
LINK_POLICY=detect
ENABLE_CSRF=true
DATABASE_TEMPLATES=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

ADMIN_EMAIL=admin@example.com
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Person

JWT_SECRET=
# Generate with: php artisan jwt:secret

# Centrifugo WebSocket Configuration (see plugins/golem15/websockets/README.md).
# These MUST match your running Centrifugo's config.json:
#   CENTRIFUGO_SECRET   = Centrifugo  client.token.hmac_secret_key  (backend signs
#                         the per-user connection JWT; Centrifugo verifies it)
#   CENTRIFUGO_API_KEY  = Centrifugo  http_api.key
#   CENTRIFUGO_API_URL  = http://<centrifugo-host>:<port>/api
# The frontend connects to ws://<host>:<port>/connection/websocket and its origin
# must be in Centrifugo client.allowed_origins. The backend mints tokens at the
# jwt.auth-gated GET /api/realtime/token.
CENTRIFUGO_SECRET=
CENTRIFUGO_API_KEY=
CENTRIFUGO_API_URL=http://127.0.0.1:8001/api
CENTRIFUGO_WS_URL=/ws
CENTRIFUGO_TOKEN_TTL=3600
CENTRIFUGO_PROXY_SECRET=
# Generate secrets with: php -r "echo bin2hex(random_bytes(32));"

# Broadcasting
BROADCAST_DRIVER=centrifugo
BROADCAST_ENABLED=true
BROADCAST_NAMESPACE=
BROADCAST_QUEUE=broadcasts

# Chat plugin
# ui-avatars.com fallback for missing avatars (sends only initials, e.g. "J+Z").
# Enabled by default. Set to false to disable external avatar requests entirely.
# CHAT_USE_UI_AVATARS=true

# Push Notifications (VAPID)
PUSH_ENABLED=false
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:support@example.com

# Search (Typesense via Laravel Scout — Inventory plugin)
# SCOUT_DRIVER must be "typesense" or Scout uses the in-memory collection driver.
# TYPESENSE_PORT 8181 maps to the container's internal 8108 (see run-typesense.sh).
SCOUT_DRIVER=typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8181
TYPESENSE_API_KEY=

# Organisation AI org-lock (Inventory plugin, Phase 12 — D-04).
# When true, the per-user AI credential tier is SKIPPED server-side for every
# ORG MEMBER and the shared organisation credential is used instead (even if a
# per-user row exists). Org-less users (orphans) keep their own per-user key (D-06).
# Authoritative in PHP (AiGate + AiConfigResolver), not merely hidden in the SPA.
INVENTORY_AI_ORG_LOCK=false
